# Copy this file to .env on your server and fill real values there.
# Never commit real secrets.

# Runtime mode
APP_ENV=development
NODE_ENV=development

# Service ports
API_PORT=8000
WEB_PORT=3000

# Database settings
POSTGRES_DB=lawn
POSTGRES_USER=lawn
POSTGRES_PASSWORD=replace-with-strong-random-password
DATABASE_URL=postgresql+psycopg://lawn:replace-with-strong-random-password@db:5432/lawn

# Integrations (placeholders only)
RACHIO_API_KEY=replace-when-available
ANTHROPIC_API_KEY=placeholder-not-used-in-phase-1

# Frontend config
NEXT_PUBLIC_API_BASE_URL=http://lawn-api:8000
